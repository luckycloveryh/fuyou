<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>格式化 on 小杨的博客</title><link>https://luckycloveryh.github.io/fuyou/tags/%E6%A0%BC%E5%BC%8F%E5%8C%96/</link><description>Recent content in 格式化 on 小杨的博客</description><generator>Hugo -- gohugo.io</generator><language>zh-cn</language><copyright>小杨</copyright><lastBuildDate>Sun, 05 Apr 2026 14:30:00 +0800</lastBuildDate><atom:link href="https://luckycloveryh.github.io/fuyou/tags/%E6%A0%BC%E5%BC%8F%E5%8C%96/index.xml" rel="self" type="application/rss+xml"/><item><title>Markdown 完全语法教程</title><link>https://luckycloveryh.github.io/fuyou/p/markdown-%E5%AE%8C%E5%85%A8%E8%AF%AD%E6%B3%95%E6%95%99%E7%A8%8B/</link><pubDate>Sun, 05 Apr 2026 14:30:00 +0800</pubDate><guid>https://luckycloveryh.github.io/fuyou/p/markdown-%E5%AE%8C%E5%85%A8%E8%AF%AD%E6%B3%95%E6%95%99%E7%A8%8B/</guid><description>&lt;img src="https://i.imgs.ovh/2026/04/06/ZQG89Y.jpeg" alt="Featured image of post Markdown 完全语法教程" />&lt;h2 id="标题">标题
&lt;/h2>&lt;p>Markdown 使用 &lt;code>#&lt;/code> 表示标题，越多 &lt;code>#&lt;/code> 表示越低级的标题。&lt;/p>
&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;span class="lnt">2
&lt;/span>&lt;span class="lnt">3
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-markdown" data-lang="markdown">&lt;span class="line">&lt;span class="cl">&lt;span class="gh"># 一级标题
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="gh">&lt;/span>&lt;span class="gu">## 二级标题
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="gu">### 三级标题
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h2 id="文本格式">文本格式
&lt;/h2>&lt;h3 id="强调">强调
&lt;/h3>&lt;ul>
&lt;li>&lt;strong>加粗文本&lt;/strong> 使用 &lt;code>**&lt;/code> 或 &lt;code>__&lt;/code>&lt;/li>
&lt;li>&lt;em>斜体文本&lt;/em> 使用 &lt;code>*&lt;/code> 或 &lt;code>_&lt;/code>&lt;/li>
&lt;li>&lt;em>&lt;strong>粗斜体&lt;/strong>&lt;/em> 使用 &lt;code>***&lt;/code>&lt;/li>
&lt;li>&lt;del>删除线&lt;/del> 使用 &lt;code>~~&lt;/code>&lt;/li>
&lt;/ul>
&lt;h3 id="引用">引用
&lt;/h3>&lt;blockquote>
&lt;p>这是一个引用&lt;/p>
&lt;p>引用可以包含多行&lt;/p>
&lt;/blockquote>
&lt;h2 id="列表">列表
&lt;/h2>&lt;h3 id="无序列表">无序列表
&lt;/h3>&lt;ul>
&lt;li>项目1&lt;/li>
&lt;li>项目2
&lt;ul>
&lt;li>嵌套项目&lt;/li>
&lt;li>另一个嵌套项目&lt;/li>
&lt;/ul>
&lt;/li>
&lt;li>项目3&lt;/li>
&lt;/ul>
&lt;h3 id="有序列表">有序列表
&lt;/h3>&lt;ol>
&lt;li>第一项&lt;/li>
&lt;li>第二项&lt;/li>
&lt;li>第三项
&lt;ol>
&lt;li>嵌套项&lt;/li>
&lt;li>嵌套项&lt;/li>
&lt;/ol>
&lt;/li>
&lt;/ol>
&lt;h2 id="代码">代码
&lt;/h2>&lt;h3 id="行内代码">行内代码
&lt;/h3>&lt;p>使用 &lt;code>code&lt;/code> 来表示行内代码。&lt;/p>
&lt;h3 id="代码块">代码块
&lt;/h3>&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;span class="lnt">2
&lt;/span>&lt;span class="lnt">3
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-python" data-lang="python">&lt;span class="line">&lt;span class="cl">&lt;span class="k">def&lt;/span> &lt;span class="nf">hello_world&lt;/span>&lt;span class="p">():&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="nb">print&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="s2">&amp;#34;Hello, World!&amp;#34;&lt;/span>&lt;span class="p">)&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="k">return&lt;/span> &lt;span class="kc">True&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;span class="lnt">2
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-javascript" data-lang="javascript">&lt;span class="line">&lt;span class="cl">&lt;span class="kr">const&lt;/span> &lt;span class="nx">greeting&lt;/span> &lt;span class="o">=&lt;/span> &lt;span class="s2">&amp;#34;Hello, Markdown!&amp;#34;&lt;/span>&lt;span class="p">;&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="nx">console&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">log&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="nx">greeting&lt;/span>&lt;span class="p">);&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
